# =============================================================================
# 复制本文件为 .env.local 后填写。密钥不要提交到 Git。
# 本项目使用 OpenAI 官方 SDK，只要服务商提供「OpenAI 兼容」HTTP 接口即可接入。
# 请求不再使用 response_format=json_object，以便豆包等模型兼容（靠提示词 + 解析 JSON）。
# 各平台「免费试用 / 赠送额度」以官网最新说明为准，会随活动变化。
# =============================================================================

# ---------------------------------------------------------------------------
# 方式 A：OpenAI 官方（需网络可达 api.openai.com，且账户有额度）
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# 方式 B：DeepSeek（国内常用，价格低；官网注册后创建 API Key）
# 文档：https://api-docs.deepseek.com/
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# 方式 C：月之暗面 Moonshot（Kimi）；控制台创建 API Key
# 文档：https://platform.moonshot.cn/docs
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# ---------------------------------------------------------------------------
# 方式 D：硅基流动 SiliconFlow（多开源模型；额度政策见官网）
# 文档：https://docs.siliconflow.cn/
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---------------------------------------------------------------------------
# 方式 E：阿里云通义 DashScope（OpenAI 兼容模式；需开通模型服务）
# 文档：https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=你的DashScope_API_Key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-turbo

# ---------------------------------------------------------------------------
# 方式 F：火山引擎 火山方舟 · 豆包（OpenAI 兼容 SDK）
# 文档：https://www.volcengine.com/docs/82379/1330626
# API Key：方舟控制台「API Key 管理」创建（填到下方 OPENAI_API_KEY）
# 说明：model 一般为模型名（如下）或控制台给出的「接入点 ID」（ep-xxxx）；以控制台为准。
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=你的方舟_API_Key
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=doubao-seed-2-0-pro-260215

# ---------------------------------------------------------------------------
# 最小示例（复制到 .env.local，把 Key 换成你在控制台创建的）
# 可换成上面 B～F 中任意一组。
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-从厂商控制台复制
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# 可选：请求超时（毫秒），默认 600000
# OPENAI_TIMEOUT_MS=600000

# 可选：连接失败时最大重试次数 0–2，默认 1
# OPENAI_MAX_RETRIES=1
